# Supabase — public anon key, baked into the bundle at build time.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Affiliate program codes (Phase 1 — buy links).
# Builds still work without these; URLs just lose affiliate attribution.

# Card Kingdom partner code (e.g. "vault"). Goes into ?partner=<code>.
VITE_CARDKINGDOM_PARTNER=

# TCGplayer deep-link prefix from Impact, e.g.
# "https://impact.example/click?irgwc=1" — the helper appends `&u=<encoded url>`.
# Do NOT include a trailing `u=`; we add it.
VITE_TCGPLAYER_IMPACT_PREFIX=

# Cardmarket "refer a friend" username — displayed in the EU signup CTA.
# Cardmarket attributes referrals at signup only; there is no per-URL affiliate.
VITE_CARDMARKET_REFERRER_USERNAME=

# Tip jar (Phase 2b). PayPal.Me URL — the modal builds preset $3/$5/$10
# links and a custom-amount field off this base. If unset, the modal
# falls back to a "tipping not configured" message and the Cardmarket
# EU referral CTA. Example: https://paypal.me/yourname
VITE_PAYPAL_ME_URL=
